(module
  (import "wasi_snapshot_preview1" "fd_read" (func $fd_read (param i32 i32 i32 i32)(result i32)))
  (import "wasi_snapshot_preview1" "fd_write" (func $fd_write (param i32 i32 i32 i32)(result i32)))
  (memory (export "memory") 1024)
  ;; 0=iovec 16=buf_a 0x2000000=buf_b 0x3F00000=input
  (global $h (mut i32)(i32.const 0))  ;; head (write cursor into dst)
  (global $c (mut i32)(i32.const 0))  ;; changed flag

  ;; skip one balanced tree at pos in memory, return pos after
  (func $s (param $p i32)(result i32)(local $d i32)
    (local.set $d (i32.const 1))
    (block $x(loop $l (br_if $x (i32.eqz(local.get $d)))
      (if (i32.eq(i32.load8_u(local.get $p))(i32.const 0x31))
        (then(local.set $d(i32.sub(local.get $d)(i32.const 1))))
        (else(local.set $d(i32.add(local.get $d)(i32.const 1)))))
      (local.set $p(i32.add(local.get $p)(i32.const 1)))(br $l)))
    (local.get $p))

  ;; copy one balanced tree from p to $h, return new p
  (func $cp (param $p i32)(result i32)(local $d i32)
    (local.set $d (i32.const 1))
    (block $x(loop $l (br_if $x(i32.eqz(local.get $d)))
      (i32.store8(global.get $h)(i32.load8_u(local.get $p)))
      (if (i32.eq(i32.load8_u(local.get $p))(i32.const 0x31))
        (then(local.set $d(i32.sub(local.get $d)(i32.const 1))))
        (else(local.set $d(i32.add(local.get $d)(i32.const 1)))))
      (local.set $p(i32.add(local.get $p)(i32.const 1)))
      (global.set $h(i32.add(global.get $h)(i32.const 1)))(br $l)))
    (local.get $p))

  ;; emit one byte
  (func $e (param i32)
    (i32.store8(global.get $h)(local.get 0))
    (global.set $h(i32.add(global.get $h)(i32.const 1))))

  ;; Walk one tree at p, rewriting redexes. Returns p' (after tree).
  ;; Writes rewritten tree to $h. Sets $c=1 if any rewrite happened.
  (func $w (param $p i32)(result i32)
    (local $ga i32)(local $gb i32)(local $gc i32)(local $wa i32)
    ;; leaf
    (if (i32.eq(i32.load8_u(local.get $p))(i32.const 0x31))
      (then (call $e(i32.const 0x31))(return(i32.add(local.get $p)(i32.const 1)))))
    ;; application: p[0]='0'. Check if p[1..3]='001' (fork = redex)
    (if (i32.and
          (i32.eq(i32.load8_u(i32.add(local.get $p)(i32.const 1)))(i32.const 0x30))
          (i32.and
            (i32.eq(i32.load8_u(i32.add(local.get $p)(i32.const 2)))(i32.const 0x30))
            (i32.eq(i32.load8_u(i32.add(local.get $p)(i32.const 3)))(i32.const 0x31))))
      (then
        ;; Redex: apply(fork(a,b), c). a starts at p+4
        (local.set $ga (call $s(i32.add(local.get $p)(i32.const 4))))
        (local.set $gb (call $s(local.get $ga)))
        (local.set $gc (call $s(local.get $gb)))
        ;; a=leaf: emit b
        (if (i32.eq(i32.load8_u(i32.add(local.get $p)(i32.const 4)))(i32.const 0x31))
          (then (global.set $c(i32.const 1))
            (drop(call $cp(local.get $ga)))
            (return(local.get $gc))))
        ;; a=stem(a'): emit 00a'c0bc
        (if (i32.eq(i32.load8_u(i32.add(local.get $p)(i32.const 5)))(i32.const 0x31))
          (then (global.set $c(i32.const 1))
            (call $e(i32.const 0x30))(call $e(i32.const 0x30))
            (drop(call $cp(i32.add(local.get $p)(i32.const 6))))
            (drop(call $cp(local.get $gb)))
            (call $e(i32.const 0x30))
            (drop(call $cp(local.get $ga)))
            (drop(call $cp(local.get $gb)))
            (return(local.get $gc))))
        ;; a=fork(a1,a2): triage on c — but only if c is a value
        ;; c is a value if it starts with 1, 01, or 001
        ;; If c starts with 000... it's a non-value application
        (if (i32.eq(i32.load8_u(local.get $gb))(i32.const 0x31))
          ;; c=leaf: emit a1 (rule 3a)
          (then (global.set $c(i32.const 1))
            (drop(call $cp(i32.add(local.get $p)(i32.const 7))))
            (return(local.get $gc))))
        (if (i32.eq(i32.load8_u(i32.add(local.get $gb)(i32.const 1)))(i32.const 0x31))
          ;; c starts with 01: c=stem(d), emit 0 a2 d (rule 3b)
          (then (global.set $c(i32.const 1))
            (call $e(i32.const 0x30))
            (local.set $wa(call $s(i32.add(local.get $p)(i32.const 7))))
            (drop(call $cp(local.get $wa)))
            (drop(call $cp(i32.add(local.get $gb)(i32.const 2))))
            (return(local.get $gc))))
        (if (i32.eq(i32.load8_u(i32.add(local.get $gb)(i32.const 2)))(i32.const 0x31))
          ;; c starts with 001: c=fork(d,e), emit 00 b d e (rule 3c)
          (then (global.set $c(i32.const 1))
            (call $e(i32.const 0x30))(call $e(i32.const 0x30))
            (drop(call $cp(local.get $ga)))
            (drop(call $cp(i32.add(local.get $gb)(i32.const 3))))
            (drop(call $cp(call $s(i32.add(local.get $gb)(i32.const 3)))))
            (return(local.get $gc))))
        ;; c is not a value: can't apply rule 3. Copy fork, walk c.
        (call $e(i32.const 0x30))
        (drop(call $cp(i32.add(local.get $p)(i32.const 1))))  ;; copy 001ab
        (return(call $w(local.get $gb)))))
    ;; Non-redex application: emit 0, walk left subtree, walk right subtree
    (call $e(i32.const 0x30))
    (local.set $p(call $w(i32.add(local.get $p)(i32.const 1))))
    (call $w(local.get $p)))

  ;; One pass: walk tree at src, write to dst. Returns length written.
  (func $pass (param $src i32)(param $len i32)(param $dst i32)(result i32)
    (global.set $h(local.get $dst))
    (drop(call $w(local.get $src)))
    (i32.sub(global.get $h)(local.get $dst)))

  ;; reduce to normal form: alternate between buf_a(16) and buf_b(0x2000000)
  (func $reduce (param $buf i32)(param $len i32)(result i32 i32)
    (local $dst i32)
    (block $done (loop $lp
      (local.set $dst (if (result i32)(i32.eq(local.get $buf)(i32.const 16))(then(i32.const 0x2000000))(else(i32.const 16))))
      (global.set $c(i32.const 0))
      (local.set $len(call $pass(local.get $buf)(local.get $len)(local.get $dst)))
      (local.set $buf(local.get $dst))
      (br_if $done(i32.eqz(global.get $c)))
      (br $lp)))
    (local.get $buf)(local.get $len))

  ;; read one line into 0x3F00000, return length (-1 on eof)
  (func $rl (result i32)(local $t i32)(local $n i32)(local $b i32)
    (block $eof(loop $l
      (i32.store(i32.const 0)(i32.add(i32.const 0x3F00000)(local.get $t)))
      (i32.store(i32.const 4)(i32.const 1))
      (drop(call $fd_read(i32.const 0)(i32.const 0)(i32.const 1)(i32.const 8)))
      (local.set $n(i32.load(i32.const 8)))
      (br_if $eof(i32.eqz(local.get $n)))
      (local.set $b(i32.load8_u(i32.add(i32.const 0x3F00000)(local.get $t))))
      (if(i32.eq(local.get $b)(i32.const 0x0A))(then(return(local.get $t))))
      (if(i32.ne(local.get $b)(i32.const 0x0D))
        (then(local.set $t(i32.add(local.get $t)(i32.const 1)))))
      (br $l)))
    (if(result i32)(i32.gt_u(local.get $t)(i32.const 0))(then(local.get $t))(else(i32.const -1))))

  ;; memcpy n bytes from s to d
  (func $mc (param $d i32)(param $s i32)(param $n i32)(local $i i32)
    (block $x(loop $l(br_if $x(i32.ge_u(local.get $i)(local.get $n)))
      (i32.store8(i32.add(local.get $d)(local.get $i))(i32.load8_u(i32.add(local.get $s)(local.get $i))))
      (local.set $i(i32.add(local.get $i)(i32.const 1)))(br $l))))

  (func (export "_start") (local $buf i32)(local $len i32)(local $ll i32)(local $dst i32)
    ;; Init: identity = 001010111 at buf_a (offset 16)
    (i64.store(i32.const 16)(i64.const 0x3131303130313030))  ;; "00101011" LE
    (i32.store8(i32.const 24)(i32.const 0x31))                ;; "1"
    (local.set $buf(i32.const 16))(local.set $len(i32.const 9))
    ;; Read lines, apply each as argument
    (block $done(loop $lp
      (local.set $ll(call $rl))
      (br_if $done(i32.lt_s(local.get $ll)(i32.const 0)))
      (if(i32.gt_u(local.get $ll)(i32.const 0))(then
        ;; Build "0" + expr + input at dst buf
        (local.set $dst(if(result i32)(i32.eq(local.get $buf)(i32.const 16))(then(i32.const 0x2000000))(else(i32.const 16))))
        (i32.store8(local.get $dst)(i32.const 0x30))
        (call $mc(i32.add(local.get $dst)(i32.const 1))(local.get $buf)(local.get $len))
        (call $mc(i32.add(i32.add(local.get $dst)(i32.const 1))(local.get $len))(i32.const 0x3F00000)(local.get $ll))
        (local.set $len(i32.add(i32.add(local.get $len)(i32.const 1))(local.get $ll)))
        (local.set $buf(local.get $dst))
        (call $reduce(local.get $buf)(local.get $len))
        (local.set $len)(local.set $buf)
      ))
      (br $lp)))
    ;; write output
    (i32.store8(i32.add(local.get $buf)(local.get $len))(i32.const 0x0A))
    (i32.store(i32.const 0)(local.get $buf))
    (i32.store(i32.const 4)(i32.add(local.get $len)(i32.const 1)))
    (drop(call $fd_write(i32.const 1)(i32.const 0)(i32.const 1)(i32.const 8))))
)
